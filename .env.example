# Supabase — safe for client bundles (public by design)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# RevenueCat — public API key, safe for client bundles
EXPO_PUBLIC_REVENUECAT_API_KEY=your-revenuecat-api-key-here

# PostHog analytics — public by design (safe for client bundles)
EXPO_PUBLIC_POSTHOG_KEY=phc_your_project_api_key_here
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---------------------------------------------------------------------------
# AI / Claude API key
# ---------------------------------------------------------------------------
# The Anthropic API key lives server-side only as a Supabase Edge Function secret.
# It is NOT an EXPO_PUBLIC_ variable and never reaches the client bundle.
# Set it with:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#
# DO NOT add EXPO_PUBLIC_ANTHROPIC_API_KEY or EXPO_PUBLIC_CLAUDE_API_KEY here.
