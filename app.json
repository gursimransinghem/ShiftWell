{
  "expo": {
    "name": "ShiftWell",
    "slug": "shiftwell",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "shiftwell",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080B14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.shiftwell.app",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": true
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": ["E174.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": ["35F9.1"]
          }
        ]
      },
      "infoPlist": {
        "NSDocumentPickerUsageDescription": "ShiftWell needs access to your files to import shift schedules.",
        "NSHealthShareUsageDescription": "ShiftWell uses Apple Health data, including sleep records and heart rate variability from your Apple Watch, to optimize your sleep schedule and calculate your recovery score.",
        "NSHealthUpdateUsageDescription": "ShiftWell does not write health data.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSCalendarsFullAccessUsageDescription": "ShiftWell reads your calendar to detect work shifts and writes sleep blocks back as events.",
        "NSCalendarsWriteOnlyAccessUsageDescription": "ShiftWell adds sleep plan events to your calendar.",
        "UIBackgroundModes": ["fetch", "remote-notification", "processing"],
        "BGTaskSchedulerPermittedIdentifiers": ["com.expo.modules.backgroundtask.processing"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#080B14",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.shiftwell.app",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-document-picker",
      "expo-file-system",
      "expo-sharing",
      "expo-secure-store",
      "expo-apple-authentication",
      "expo-notifications",
      ["expo-location", {
        "locationWhenInUsePermission": "ShiftWell uses your location to calculate your commute time."
      }],
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "ShiftWell uses Apple Health data, including sleep records and heart rate variability from your Apple Watch, to optimize your sleep schedule and calculate your recovery score.",
          "NSHealthUpdateUsageDescription": "ShiftWell does not write health data."
        }
      ],
      "expo-calendar",
      "expo-background-task",
      "expo-task-manager",
      ["@react-native-google-signin/google-signin", {
        "iosUrlScheme": "com.googleusercontent.apps.PLACEHOLDER_CLIENT_ID"
      }],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "shiftwell",
          "organization": "YOUR_ORG_SLUG"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
